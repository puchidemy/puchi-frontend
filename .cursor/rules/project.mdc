### Client setup

```typescript
// src/lib/limen-auth.ts
createAuthClient({
  baseURL: NEXT_PUBLIC_API_URL,  // https://api.puchi.io.vn
  basePath: "/auth",
  plugins: [credentialPasswordPlugin(), oauthClientPlugin(), bearerPlugin()],
})
```

### AuthProvider

```typescript
// src/providers/AuthProvider.tsx
const auth = useAuth()
auth.login(email, password)     // authClient.signIn.credential
auth.register(email, password)  // authClient.signUp.credential
auth.logout()                   // authClient.signOut
auth.refreshSession()           // authClient.getSession
```

